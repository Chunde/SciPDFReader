{
  "name": "scipdfreader",
  "version": "0.0.1",
  "displayName": "SciPDFReader",
  "description": "AI-powered PDF Reader with annotation and plugin support",
  "main": "./out/main.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "start": "electron .",
    "package": "electron-builder",
    "lint": "eslint src --ext ts"
  },
  "author": "SciPDFReader Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.scipdfreader.app",
    "productName": "SciPDFReader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
